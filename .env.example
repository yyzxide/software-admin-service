# 本地开发前先复制为 .env：
#   cp .env.example .env
#
# 默认端口会避开常见的 3306 和 6379，
# 方便干净克隆后与本机已有 MySQL / Redis 共存。

ADMIN_SERVER_PORT=8090
ADMIN_BASE_URL=http://127.0.0.1:8090
ADMIN_OPENAPI_SERVER_URL=http://127.0.0.1:8090

ADMIN_DB_HOST=127.0.0.1
ADMIN_DB_HOST_PORT=3308
ADMIN_DB_PORT=3308
ADMIN_DB_NAME=db_java_software_admin
ADMIN_DB_USERNAME=root
ADMIN_DB_PASSWORD=root123456
ADMIN_DB_URL=jdbc:mysql://127.0.0.1:3308/db_java_software_admin?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true

ADMIN_REDIS_HOST=127.0.0.1
ADMIN_REDIS_HOST_PORT=6381
ADMIN_REDIS_PORT=6381
ADMIN_REDIS_PASSWORD=
ADMIN_REDIS_DATABASE=0

# JWT HS256 密钥至少 32 字节；非本地环境必须替换为随机密钥。
ADMIN_SECURITY_TOKEN_SECRET=change-me-local-development-secret
ADMIN_SECURITY_TTL_SECONDS=7200

ADMIN_UPLOAD_MAX_FILE_SIZE=500MB
ADMIN_UPLOAD_MAX_REQUEST_SIZE=600MB
ADMIN_UPLOAD_MAX_PACKAGE_SIZE=500MB
ADMIN_UPLOAD_PACKAGE_DIR=./storage/packages
ADMIN_UPLOAD_SIGNATURE_PUBLIC_KEY_PEM=
ADMIN_UPLOAD_CLEANUP_ENABLED=true
ADMIN_UPLOAD_CLEANUP_EXPIRE_HOURS=24
ADMIN_UPLOAD_CLEANUP_BATCH_SIZE=100
ADMIN_UPLOAD_CLEANUP_FIXED_DELAY_MS=3600000
